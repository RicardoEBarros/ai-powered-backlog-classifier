{
    "compilerOptions": {
        "outDir": "dist",
        "target": "es2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "strict": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "types": [
            "node"
        ],
    },
    "ts-node": {
        "esm": true,
        "experimentalSpecifierResolution": "node"
    },
    "exclude": [
        "node_modules",
        "dist",
        "coverage"
    ]
}